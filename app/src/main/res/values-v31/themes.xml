<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.CarKarma" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- SFONDO: Il colore della tua app (definito in colors.xml) -->
        <item name="android:windowBackground">@color/app_background_color</item>

        <!-- TRUCCO: ICONA TRASPARENTE (Solo per Android 12+) -->
        <!-- Questo nasconde quel logo "tagliato" o nel cerchio nero -->
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>

        <!-- Assicuriamo che lo sfondo della splash coincida col windowBackground -->
        <item name="android:windowSplashScreenBackground">@color/app_background_color</item>
    </style>
</resources>