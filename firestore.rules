rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------
    // 1. UTENTI PUBBLICI (Rubrica per inviti)
    // ---------------------------------------------------------
    // Chiunque sia autenticato può LEGGERE per trovare amici tramite email.
    // Ma solo il proprietario dell'account può SCRIVERE/MODIFICARE i propri dati.
    match /public_users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------
    // 2. COLLEZIONE GRUPPI E SOTTOCOLLEZIONI (Membri, Uscite)
    // ---------------------------------------------------------
    // Attualmente, per la fase Beta tra amici, permettiamo l'accesso
    // a chiunque sia loggato nell'app.
    // In una versione futura (Produzione), qui andrà aggiunto il controllo:
    // allow read, write: if request.auth != null && request.auth.uid in resource.data.utentiIds;
    match /gruppi/{gruppoId} {
      allow read, write: if request.auth != null;

      // Regole per le sottocollezioni (ereditano l'accesso se non specificato diversamente,
      // ma esplicitiamolo per chiarezza).
      match /membri/{membroId} {
        allow read, write: if request.auth != null;
      }
      match /uscite/{uscitaId} {
        allow read, write: if request.auth != null;
      }
    }

    // ---------------------------------------------------------
    // 3. ALTRE COLLEZIONI (Default Deny)
    // ---------------------------------------------------------
    // Blocca tutto il resto per sicurezza
    match /{document=**} {
      allow read, write: if false;
    }
  }
}