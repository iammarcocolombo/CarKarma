rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. UTENTI PUBBLICI (Per gli inviti)
    match /public_users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. RUBRICA PERSONALE (QUESTA MANCAVA!)
    // Ogni utente può leggere e scrivere SOLO nella propria cartella
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 3. GRUPPI
    // Per ora permettiamo l'accesso ai loggati (in futuro si restringe ai membri)
    match /gruppi/{gruppoId} {
      allow read, write: if request.auth != null;

      match /membri/{membroId} {
        allow read, write: if request.auth != null;
      }
      match /uscite/{uscitaId} {
        allow read, write: if request.auth != null;
      }
    }

    // Blocca tutto il resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}